---
interface Props {
  as?: 'span' | 'p' | 'div';
  tone?: 'red' | 'fg' | 'inverse';
  bar?: boolean;
  class?: string;
}

const { as = 'span', tone = 'red', bar = false, class: className = '' } = Astro.props;
const Tag = as;

const toneClass = {
  red: 'text-red',
  fg: 'text-fg-muted',
  inverse: 'text-white/70',
}[tone];

const barClass = {
  red: 'bg-red',
  fg: 'bg-fg-muted',
  inverse: 'bg-white/40',
}[tone];
---
<Tag
  class:list={[
    'inline-flex items-center gap-3 text-[0.75rem] font-semibold uppercase',
    toneClass,
    className,
  ]}
  style="letter-spacing: var(--ls-eyebrow); font-family: var(--font-body);"
>
  {bar && <span aria-hidden="true" class:list={['block h-[2px] w-7', barClass]} />}
  <slot />
</Tag>
