---
interface Props {
  as?: 'span' | 'p' | 'div';
  /**
   * · stone   → default · grafito sobre claros (uso institucional)
   * · red     → ceremonial · sólo para momentos brand muy específicos
   * · fg      → utility · neutro fg-muted con barra fg
   * · inverse → sobre fondos oscuros (stone-700 / inverse)
   * · sage    → para contextos sustainability
   */
  tone?: 'stone' | 'red' | 'fg' | 'inverse' | 'sage';
  bar?: boolean;
  class?: string;
}

const { as = 'span', tone = 'stone', bar = false, class: className = '' } = Astro.props;
const Tag = as;

const toneClass = {
  stone:   'text-stone-700',
  red:     'text-red-700',
  fg:      'text-fg-muted',
  inverse: 'text-white/75',
  sage:    'text-green',
}[tone];

const barClass = {
  stone:   'bg-stone-600',
  red:     'bg-red',
  fg:      'bg-fg-muted',
  inverse: 'bg-white/45',
  sage:    'bg-green',
}[tone];
---
<Tag
  class:list={[
    'inline-flex items-center gap-3 text-[0.75rem] font-semibold uppercase',
    toneClass,
    className,
  ]}
  style="letter-spacing: var(--ls-eyebrow); font-family: var(--font-body);"
>
  {bar && <span aria-hidden="true" class:list={['block h-[2px] w-7', barClass]} />}
  <slot />
</Tag>
