---
const pillars = [
  {
    num: '01',
    title: 'Estándares internacionales',
    body: 'Diseñamos y construimos bajo normas técnicas y arquitectónicas reconocidas globalmente, con foco en seguridad, calidad y trazabilidad.',
  },
  {
    num: '02',
    title: 'Sostenibilidad operativa',
    body: 'Reutilización del 100% del material de escombro y sistemas de recirculación de agua en cada obra. La sostenibilidad es un dato técnico, no un eslogan.',
  },
  {
    num: '03',
    title: 'Equipo y confianza',
    body: '+400 colaboradores formados en una cultura organizacional basada en la confianza, el desarrollo y la excelencia técnica.',
  },
];
---
<section id="nosotros" class="philo">
  <div class="container">
    <div class="intro">
      <span class="eyebrow">Filosofía Convel</span>
      <h2>Realizamos <span class="accent">sueños.</span></h2>
      <p>No levantamos paredes. Construimos espacios que duran y dejan huella en quienes los habitan.</p>
    </div>
    <div class="pillars">
      {pillars.map((p) => (
        <div class="pillar">
          <div class="num">{p.num}</div>
          <div>
            <h4>{p.title}</h4>
            <p>{p.body}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .philo {
    background: #fff;
    padding: 96px var(--container-pad);
  }

  .container {
    max-width: var(--container-max);
    margin: 0 auto;
    display: grid;
    grid-template-columns: 5fr 7fr;
    gap: 64px;
    align-items: start;
  }

  .eyebrow {
    color: var(--convel-red);
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    display: block;
    margin-bottom: 16px;
  }

  h2 {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(36px, 5vw, 64px);
    line-height: 1;
    letter-spacing: -0.03em;
  }

  h2 .accent { color: var(--convel-red); }

  .intro p {
    margin-top: 20px;
    font-size: 16px;
    line-height: 1.55;
    color: var(--fg-muted);
    max-width: 36ch;
  }

  .pillars {
    display: grid;
    gap: 32px;
  }

  .pillar {
    display: grid;
    grid-template-columns: 36px 1fr;
    gap: 18px;
    align-items: start;
    padding-top: 24px;
    border-top: 1px solid var(--border);
  }

  .pillar:first-child {
    border-top: 0;
    padding-top: 0;
  }

  .num {
    font-family: var(--font-mono);
    font-size: 14px;
    color: var(--convel-red);
    font-weight: 500;
    padding-top: 4px;
  }

  .pillar h4 {
    font-family: var(--font-display);
    font-size: 22px;
    font-weight: 600;
    letter-spacing: -0.015em;
    margin: 0 0 6px;
  }

  .pillar p {
    font-size: 15px;
    line-height: 1.55;
    color: var(--fg-muted);
    margin: 0;
    max-width: 56ch;
  }

  @media (max-width: 860px) {
    .container {
      grid-template-columns: 1fr;
      gap: 40px;
    }
  }
</style>
