---
const projects = [
  {
    id: 1,
    tag: 'Residencial · 2024',
    title: 'Vegas 48',
    body: '18 unidades de vivienda en El Poblado. Certificación LEED Gold y reutilización del 100% de escombro de obra.',
    cat: 'Residencial',
    variant: 'a',
    tall: true,
  },
  {
    id: 2,
    tag: 'Comercial · 2025',
    title: 'Wake Provenza',
    body: 'Centro de uso mixto en Provenza, con espacios comerciales, oficinas y plaza pública integrada.',
    cat: 'Comercial',
    variant: 'b',
    tall: false,
  },
  {
    id: 3,
    tag: 'Logístico · 2023',
    title: 'Centro Logístico Norte',
    body: 'Operación industrial de 38.000 m². Sistemas de recirculación de agua y techos solares.',
    cat: 'Logístico',
    variant: 'c',
    tall: false,
  },
];

const categories = ['Todos', 'Residencial', 'Comercial', 'Industrial', 'Logístico', 'Público'];
---
<section id="proyectos" class="projects">
  <div class="container">
    <div class="sec-head">
      <div class="l">
        <span class="eyebrow">Proyectos destacados</span>
        <h2>Edificaciones de <span class="accent">alto impacto.</span></h2>
      </div>
      <a class="btn btn-outline btn-arrow" href="#">Ver portafolio completo</a>
    </div>

    <div class="filters" role="tablist">
      {categories.map((c, i) => (
        <button class:list={['pill', { active: i === 0 }]} data-cat={c} type="button">{c}</button>
      ))}
    </div>

    <div class="project-grid">
      {projects.map((p) => (
        <article class:list={['project', p.variant, { tall: p.tall }]} data-cat={p.cat}>
          <div class="img" aria-hidden="true"><span class="img-tag">Imagen</span></div>
          <div class="body">
            <div class="meta">{p.tag}</div>
            <h3>{p.title}</h3>
            <p>{p.body}</p>
          </div>
        </article>
      ))}
      <p class="empty" hidden>No hay proyectos en esta categoría.</p>
    </div>
  </div>
</section>

<style>
  .projects {
    background: var(--convel-mist-25);
    padding: 96px var(--container-pad);
  }

  .container {
    max-width: var(--container-max);
    margin: 0 auto;
  }

  .sec-head {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    margin-bottom: 48px;
    gap: 32px;
    flex-wrap: wrap;
  }

  .sec-head .l { max-width: 60ch; }

  .eyebrow {
    color: var(--convel-red);
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    margin-bottom: 16px;
    display: block;
  }

  h2 {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(32px, 4.5vw, 56px);
    line-height: 1.05;
    letter-spacing: -0.025em;
  }

  h2 .accent { color: var(--convel-red); }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font: 600 13px/1 var(--font-body);
    padding: 11px 18px;
    border: 1px solid transparent;
    cursor: pointer;
    transition: all 160ms var(--ease-standard);
    letter-spacing: 0.02em;
  }

  .btn-outline {
    border-color: var(--convel-black);
    color: var(--convel-black);
    background: transparent;
  }

  .btn-outline:hover {
    background: var(--convel-black);
    color: #fff;
  }

  .btn-arrow::after {
    content: '→';
    transition: transform 160ms var(--ease-standard);
  }

  .btn-arrow:hover::after { transform: translateX(4px); }

  .filters {
    display: flex;
    gap: 8px;
    margin-bottom: 32px;
    flex-wrap: wrap;
  }

  .pill {
    font-size: 12px;
    font-weight: 500;
    padding: 8px 16px;
    border: 1px solid var(--border);
    border-radius: var(--r-pill);
    background: #fff;
    color: var(--fg);
    cursor: pointer;
    transition: all 160ms var(--ease-standard);
  }

  .pill:hover { border-color: var(--convel-black); }

  .pill.active {
    background: var(--convel-black);
    color: #fff;
    border-color: var(--convel-black);
  }

  .project-grid {
    display: grid;
    grid-template-columns: 1.4fr 1fr 1fr;
    gap: 24px;
  }

  .project {
    display: flex;
    flex-direction: column;
    background: #fff;
    border-top: 4px solid var(--convel-red);
    transition: all 220ms var(--ease-standard);
    cursor: pointer;
  }

  .project:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-3);
  }

  .project.hidden { display: none; }

  .img {
    aspect-ratio: 4 / 3;
    background: linear-gradient(135deg, #baada5 0%, #6e635b 100%);
    position: relative;
  }

  .project.tall .img { aspect-ratio: 3 / 4; }

  .project.b .img {
    background: linear-gradient(135deg, #2b2b2b 0%, #4a4a4a 50%, #baada5 100%);
  }

  .project.c .img {
    background: linear-gradient(135deg, #d4dfe7 0%, #8ea6b7 50%, #4a4a4a 100%);
  }

  .img-tag {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    color: rgba(255, 255, 255, 0.45);
    font-size: 10px;
    letter-spacing: 0.3em;
    font-weight: 600;
    text-transform: uppercase;
  }

  .body { padding: 22px 24px 24px; }

  .meta {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--convel-red);
    margin-bottom: 8px;
  }

  .project h3 {
    font-family: var(--font-display);
    font-size: 26px;
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.05;
    margin: 0 0 8px;
  }

  .project p {
    font-size: 13px;
    color: var(--fg-muted);
    line-height: 1.5;
    margin: 0;
  }

  .empty {
    grid-column: 1 / -1;
    color: var(--fg-muted);
    padding: 32px 0;
  }

  @media (max-width: 960px) {
    .project-grid { grid-template-columns: 1fr 1fr; }
    .project.tall { grid-column: 1 / -1; }
    .project.tall .img { aspect-ratio: 16 / 10; }
  }

  @media (max-width: 640px) {
    .project-grid { grid-template-columns: 1fr; }
    .project.tall { grid-column: auto; }
  }
</style>

<script>
  const root = document.querySelector('.projects');
  if (root) {
    const pills = root.querySelectorAll<HTMLButtonElement>('.pill');
    const items = root.querySelectorAll<HTMLElement>('.project');
    const empty = root.querySelector<HTMLElement>('.empty');

    pills.forEach((pill) => {
      pill.addEventListener('click', () => {
        pills.forEach((p) => p.classList.remove('active'));
        pill.classList.add('active');

        const cat = pill.dataset.cat;
        let visible = 0;
        items.forEach((el) => {
          const match = cat === 'Todos' || el.dataset.cat === cat;
          el.classList.toggle('hidden', !match);
          if (match) visible++;
        });
        if (empty) empty.hidden = visible !== 0;
      });
    });
  }
</script>
