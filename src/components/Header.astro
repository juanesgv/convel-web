---
interface Props {
  active?: string;
}
const { active = 'Proyectos' } = Astro.props;

const items = [
  { label: 'Proyectos', href: '#proyectos' },
  { label: 'Nosotros', href: '#nosotros' },
  { label: 'Sostenibilidad', href: '#sostenibilidad' },
  { label: 'Prensa', href: '#prensa' },
  { label: 'Contacto', href: '#contacto' },
];
---
<header class="site-header">
  <div class="row">
    <a href="#" class="logo" aria-label="Convel - inicio">
      <img src="/assets/logo-convel-black.png" alt="Convel" />
    </a>
    <nav class="nav" aria-label="Principal">
      {items.map((item) => (
        <a href={item.href} class={item.label === active ? 'active' : ''}>{item.label}</a>
      ))}
    </nav>
    <div class="right">
      <span class="lang"><b>ES</b> · EN</span>
      <a href="#contacto" class="btn btn-outline btn-arrow">Cotizar proyecto</a>
    </div>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: rgba(255, 255, 255, 0.96);
    border-bottom: 1px solid var(--border-soft);
    backdrop-filter: saturate(140%) blur(8px);
  }

  .row {
    max-width: var(--container-max);
    margin: 0 auto;
    padding: 18px var(--container-pad);
    display: flex;
    align-items: center;
    gap: 40px;
  }

  .logo img { height: 28px; }

  .nav {
    display: flex;
    gap: 28px;
    margin-left: 16px;
  }

  .nav a {
    font-size: 14px;
    font-weight: 500;
    color: var(--fg);
    transition: color 160ms var(--ease-standard);
  }

  .nav a:hover,
  .nav a.active { color: var(--convel-red); }

  .right {
    margin-left: auto;
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .lang {
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--fg-muted);
  }

  .lang b { color: var(--fg); }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font: 600 13px/1 var(--font-body);
    padding: 11px 18px;
    border: 1px solid transparent;
    cursor: pointer;
    transition: all 160ms var(--ease-standard);
    letter-spacing: 0.02em;
  }

  .btn-outline {
    border-color: var(--convel-black);
    color: var(--convel-black);
    background: transparent;
  }

  .btn-outline:hover {
    background: var(--convel-black);
    color: #fff;
  }

  .btn-arrow::after {
    content: '→';
    transition: transform 160ms var(--ease-standard);
  }

  .btn-arrow:hover::after { transform: translateX(4px); }

  @media (max-width: 860px) {
    .nav { display: none; }
  }
</style>
