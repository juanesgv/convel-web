---
const info = [
  { k: 'Oficina', v: 'Carrera 43A # 1-50, Torre Sur, Of. 1502 · El Poblado, Medellín' },
  { k: 'Teléfono', v: '+57 (604) 444 5500' },
  { k: 'Correo', v: 'proyectos@convel.com.co' },
  { k: 'Horario', v: 'Lun – Vie · 8:00 – 17:30 (COT)' },
];

const projectTypes = ['Residencial', 'Comercial', 'Industrial', 'Público'];
---
<section id="contacto" class="contact">
  <div class="container">
    <div class="copy">
      <span class="eyebrow">Hablemos</span>
      <h2>¿Tiene un<br />proyecto en mente<span class="accent">?</span></h2>
      <p class="lead">
        Cuéntenos su idea. Le acompañamos desde el diseño arquitectónico hasta la entrega de la obra.
      </p>
      <div class="info">
        {info.map((row) => (
          <div class="row">
            <div class="k">{row.k}</div>
            <div>{row.v}</div>
          </div>
        ))}
      </div>
    </div>
    <form class="form" id="quote-form">
      <h3>Solicitud de cotización</h3>
      <div class="grid">
        <div>
          <label for="f-name">Nombre</label>
          <input id="f-name" name="name" type="text" autocomplete="name" required />
        </div>
        <div>
          <label for="f-company">Empresa</label>
          <input id="f-company" name="company" type="text" placeholder="Opcional" />
        </div>
        <div>
          <label for="f-email">Correo</label>
          <input id="f-email" name="email" type="email" autocomplete="email" required />
        </div>
        <div>
          <label for="f-phone">Teléfono</label>
          <input id="f-phone" name="phone" type="tel" placeholder="+57 ___" />
        </div>
        <div class="full">
          <label for="f-type">Tipo de proyecto</label>
          <select id="f-type" name="type">
            {projectTypes.map((t) => <option>{t}</option>)}
          </select>
        </div>
        <div class="full">
          <label for="f-msg">Mensaje</label>
          <textarea id="f-msg" name="message" rows="3" placeholder="Cuéntenos sobre el proyecto, terreno, m², plazos."></textarea>
        </div>
      </div>
      <div class="submit">
        <span class="terms">Al enviar acepta nuestra política de tratamiento de datos.</span>
        <button class="btn btn-primary btn-arrow" type="submit">Enviar solicitud</button>
      </div>
    </form>
  </div>
</section>

<style>
  .contact {
    background: var(--convel-mist-25);
    padding: 96px var(--container-pad);
  }

  .container {
    max-width: var(--container-max);
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px;
    align-items: start;
  }

  .eyebrow {
    color: var(--convel-red);
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    display: block;
    margin-bottom: 16px;
  }

  h2 {
    font-family: var(--font-display);
    font-size: clamp(36px, 5vw, 64px);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1;
  }

  h2 .accent { color: var(--convel-red); }

  .lead {
    font-size: 18px;
    line-height: 1.55;
    color: var(--fg-muted);
    max-width: 50ch;
    margin-top: 20px;
  }

  .info {
    margin-top: 32px;
    display: grid;
    gap: 18px;
  }

  .info .row {
    display: grid;
    grid-template-columns: 100px 1fr;
    gap: 18px;
    padding-top: 14px;
    border-top: 1px solid var(--border-soft);
    font-size: 14px;
  }

  .info .k {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--fg-muted);
    padding-top: 2px;
  }

  .form {
    background: #fff;
    padding: 32px;
    border-top: 4px solid var(--convel-red);
    box-shadow: var(--shadow-2);
  }

  .form h3 {
    font-family: var(--font-display);
    font-size: 22px;
    font-weight: 700;
    letter-spacing: -0.015em;
    margin-bottom: 20px;
  }

  .grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 14px;
  }

  label {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--fg-muted);
    display: block;
    margin-bottom: 6px;
  }

  input,
  select,
  textarea {
    width: 100%;
    font-family: var(--font-body);
    font-size: 14px;
    padding: 11px 12px;
    border: 1px solid var(--border);
    background: #fff;
    color: var(--fg);
    border-radius: 0;
    transition: border-color 160ms var(--ease-standard);
  }

  input:focus,
  select:focus,
  textarea:focus {
    outline: 0;
    border-color: var(--convel-red);
  }

  textarea {
    resize: vertical;
    font-family: var(--font-body);
  }

  .full { grid-column: 1 / -1; }

  .submit {
    margin-top: 20px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 12px;
    flex-wrap: wrap;
  }

  .terms {
    font-size: 12px;
    color: var(--fg-muted);
    max-width: 36ch;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font: 600 13px/1 var(--font-body);
    padding: 13px 20px;
    border: 1px solid transparent;
    cursor: pointer;
    transition: all 160ms var(--ease-standard);
    letter-spacing: 0.02em;
  }

  .btn-primary {
    background: var(--convel-red);
    color: #fff;
  }

  .btn-primary:hover { background: var(--convel-red-700); }

  .btn-primary:active { transform: scale(0.98); }

  .btn-arrow::after {
    content: '→';
    transition: transform 160ms var(--ease-standard);
  }

  .btn-arrow:hover::after { transform: translateX(4px); }

  @media (max-width: 860px) {
    .container { grid-template-columns: 1fr; gap: 40px; }
    .grid { grid-template-columns: 1fr; }
  }
</style>

<script>
  const form = document.getElementById('quote-form') as HTMLFormElement | null;
  if (form) {
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      const btn = form.querySelector('button[type="submit"]');
      if (btn) btn.textContent = 'Enviado ✓';
    });
  }
</script>
