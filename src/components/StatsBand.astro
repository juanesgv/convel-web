---
const stats = [
  { prefix: '+', main: '65', label: ['Años de', 'experiencia'] },
  { prefix: '+', main: '400', label: ['Colaboradores', '2026'] },
  { main: '1954', label: ['Año de', 'fundación'] },
  { main: '100', suffix: '%', label: ['Reutilización', 'de escombro'] },
];
---
<section class="stats" id="sostenibilidad">
  <div class="container">
    <div class="l">
      <span class="eyebrow">En cifras</span>
      <h3>Una trayectoria<br />medible.</h3>
    </div>
    <div class="grid">
      {stats.map((s) => (
        <div class="stat">
          <div class="num">
            {s.prefix && <span class="accent">{s.prefix}</span>}
            {s.main}
            {s.suffix && <span class="accent">{s.suffix}</span>}
          </div>
          <div class="lbl">
            {s.label.map((line) => <div>{line}</div>)}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .stats {
    background: var(--convel-black);
    color: #fff;
    padding: 80px var(--container-pad);
  }

  .container {
    max-width: var(--container-max);
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 3fr;
    gap: 64px;
    align-items: center;
  }

  .l {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .eyebrow {
    color: var(--convel-red);
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  .l h3 {
    font-family: var(--font-display);
    font-size: 30px;
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.1;
    color: #fff;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
  }

  .stat {
    padding: 0 24px;
    border-left: 1px solid rgba(255, 255, 255, 0.16);
  }

  .stat:first-child {
    border-left: 0;
    padding-left: 0;
  }

  .num {
    font-family: var(--font-display);
    font-size: 64px;
    font-weight: 800;
    letter-spacing: -0.04em;
    line-height: 0.95;
  }

  .num .accent { color: var(--convel-red); }

  .lbl {
    margin-top: 10px;
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.65);
    line-height: 1.5;
  }

  @media (max-width: 960px) {
    .container { grid-template-columns: 1fr; gap: 40px; }
    .grid { grid-template-columns: repeat(2, 1fr); row-gap: 32px; }
    .stat:nth-child(3) { border-left: 0; padding-left: 0; }
  }

  @media (max-width: 480px) {
    .grid { grid-template-columns: 1fr; }
    .stat { border-left: 0; padding-left: 0; padding-bottom: 24px; border-bottom: 1px solid rgba(255,255,255,0.16); }
    .stat:last-child { border-bottom: 0; padding-bottom: 0; }
  }
</style>
