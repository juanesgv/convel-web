---
import Container from '../primitives/Container.astro';

interface Props {
  as?: 'section' | 'div' | 'article' | 'aside';
  /**
   * Atmósferas disponibles:
   * · default → warm-white (papel cálido, bg protagonista)
   * · soft    → stone-100 (concreto claro, surface secundaria)
   * · muted   → stone-200 (concreto medio, surface enfática)
   * · inverse → stone-700 (grafito cálido — NO negro)
   * · cool    → mist-25 (aire técnico, opt-in)
   * · sage    → green-50 (material orgánico, opt-in para sustainability)
   */
  tone?: 'default' | 'soft' | 'muted' | 'inverse' | 'cool' | 'sage';
  spacing?: 'sm' | 'md' | 'lg' | 'xl';
  containerSize?: 'editorial' | 'wide' | 'narrow';
  bleed?: boolean;
  id?: string;
  class?: string;
}

const {
  as = 'section',
  tone = 'default',
  spacing = 'lg',
  containerSize = 'editorial',
  bleed = false,
  id,
  class: className = '',
} = Astro.props;

const toneClass = {
  default: 'bg-bg text-fg',
  soft:    'bg-bg-soft text-fg',
  muted:   'bg-bg-muted text-fg',
  inverse: 'bg-bg-inverse text-fg-on-inverse',
  cool:    'bg-bg-cool text-fg',
  sage:    'bg-bg-sage text-fg',
}[tone];

const spacingClass = {
  sm: 'py-12 md:py-16',
  md: 'py-16 md:py-20',
  lg: 'py-20 md:py-24',
  xl: 'py-24 md:py-32',
}[spacing];

const Tag = as;
---
<Tag id={id} class:list={[toneClass, spacingClass, className]}>
  {bleed ? (
    <slot />
  ) : (
    <Container size={containerSize}>
      <slot />
    </Container>
  )}
</Tag>
